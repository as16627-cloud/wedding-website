DATABASE_URL="file:./wedding.db"
ADMIN_PASSCODE="change-this"
COUPLE_GUEST_LIST_PASSCODE="change-this-too"

# Public URL used in real SMS invite links.
PUBLIC_SITE_URL="https://your-public-wedding-site.example"

# Twilio SMS provider. Prefer API keys for production.
TWILIO_ACCOUNT_SID=""
TWILIO_API_KEY_SID=""
TWILIO_API_KEY_SECRET=""

# Local testing alternative to API keys.
TWILIO_AUTH_TOKEN=""

# Use either a Twilio sender number or a Messaging Service.
TWILIO_FROM_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""

# Australian mobile numbers that start with 04 will be converted to +61 by default.
SMS_DEFAULT_COUNTRY_CODE="+61"
