generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Guest {
  id          String  @id @default(cuid())
  fullName    String
  phoneNumber String?
  email       String?
  side        String?
  notes       String?

  inviteToken String  @unique
  rsvpToken   String? @unique

  invitedToCeremony Boolean @default(true)
  invitedToReception Boolean @default(true)
  plusOneAllowed    Boolean @default(false)
  smsSentAt         DateTime?

  rsvpResponse String @default("Not responded")
  rsvpStatus   String @default("Not responded")

  attendingCeremony  Boolean?
  attendingReception Boolean?
  bringingPlusOne    Boolean  @default(false)
  ceremonyResponse   Boolean?
  receptionResponse  Boolean?
  plusOneResponse    Boolean?
  plusOneName        String?

  dietaryRequirements String?
  guestDietary        String?
  plusOneDietary      String?
  songRequest         String?
  message             String?
  guestMessage        String?

  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PrivatePlanningData {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrivatePlanningSession {
  id        String    @id
  expiresAt DateTime
  lastSeenAt DateTime @default(now())
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([expiresAt])
  @@index([lastSeenAt])
}

model PrivatePlanningRateLimit {
  scope          String
  keyHash        String
  failedAttempts Int       @default(0)
  firstFailedAt  DateTime
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@id([scope, keyHash])
  @@index([firstFailedAt])
  @@index([lockedUntil])
}

model PrivatePlanningFile {
  id               String    @id @default(cuid())
  originalFilename String
  storageKey       String    @unique
  mimeType         String
  size             Int
  vendorId         String?
  paymentId        String?
  status           String    @default("pending")
  scanStatus       String    @default("unscanned")
  uploadedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([vendorId])
  @@index([uploadedAt])
}

model PrivatePlanningFileAuditLog {
  id        String   @id @default(cuid())
  fileId    String?
  action    String
  ipHash    String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([action])
  @@index([createdAt])
}
